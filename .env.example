# ─────────────────────────────────────────────────────────────────────────────
# K.A.I. (Kitezh) — Environment Configuration Template
# Copy this file to .env and fill in the values for your setup.
# ─────────────────────────────────────────────────────────────────────────────

# ── Remote API Bridge ─────────────────────────────────────────────────────────
# Set to 0 to run fully local (no external backend required).
# Set to 1 and fill in the values below to enable the remote bridge.
KITEZH_REMOTE_ENABLED=0

# Only required when KITEZH_REMOTE_ENABLED=1
KITEZH_REMOTE_URL=https://your-remote-backend.com
KITEZH_AI_KEY=your_secure_ai_key
KITEZH_COMMAND_SIGNING_SECRET=your_signing_secret

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Choose one: ollama | letta | llamacpp
KITEZH_LLM_BACKEND=llamacpp

# Ollama (if KITEZH_LLM_BACKEND=ollama)
KITEZH_OLLAMA_URL=http://localhost:11434
KITEZH_OLLAMA_MODEL=llama3

# Letta (if KITEZH_LLM_BACKEND=letta)
KITEZH_LETTA_URL=http://localhost:8283
# Name of the default Letta agent.  Leave KITEZH_LETTA_AGENT_ID blank and the
# engine will auto-create (or find) an agent with this name on first launch.
KITEZH_LETTA_AGENT_NAME=kai
KITEZH_LETTA_AGENT_ID=

# llama.cpp / llama-server (if KITEZH_LLM_BACKEND=llamacpp)
# Launch the server first: ./scripts/llama_server_cpu.sh  (or _gpu.sh)
KITEZH_LLAMACPP_URL=http://localhost:8080
KITEZH_LLAMACPP_MODEL=nous-hermes-2-mixtral-8x7b-dpo-gguf

# ── Web UI ────────────────────────────────────────────────────────────────────
# TCP port for the built-in chat server (python main.py --serve)
KITEZH_WEB_PORT=7860

# ── Network / Dual-homing ────────────────────────────────────────────────────
# Ethernet LAN subnet in CIDR notation.  Admin routes (/api/kai/*) are only
# reachable from this subnet; leave blank to skip the restriction (dev mode).
KITEZH_LAN_CIDR=192.168.1.0/24

# Override the admin path prefix (default: /api/kai)
# KITEZH_ADMIN_PATH_PREFIX=/api/kai

# ── Tapo Camera Integration ───────────────────────────────────────────────────
# Email address used in the Tapo app
KITEZH_TAPO_USER=your_tapo_email@example.com
# Local device password set in the Tapo app
KITEZH_TAPO_PASSWORD=your_tapo_password
# Subnet to scan for cameras — defaults to KITEZH_LAN_CIDR when unset
# KITEZH_CAMERA_SUBNET=192.168.1.0/24

# ── Wakeword Detection ────────────────────────────────────────────────────────
# Path to a custom openWakeWord .onnx model, or a bundled model name
# (e.g. "hey_jarvis").  Leave blank to disable audio wakeword listening.
KITEZH_WAKEWORD_MODEL=
KITEZH_WAKEWORD_THRESHOLD=0.5

# ── Puppy-trap ────────────────────────────────────────────────────────────────
# Discord user ID that triggers the puppy-trap cognitive routing protocol.
KITEZH_PUPPY_ID=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Remote request timeout in seconds (default: 10)
# KITEZH_TIMEOUT=10.0
